/*
 * layernorm.v - Fornax M2
 * Simplified LayerNorm: y = (x * weight) + bias
 * (In early M2, we might skip the full mean/var calculation for simplicity)
 */

module layernorm #(
    parameter DIM = 896,
    parameter WEIGHT_FILE = ""
)(
    input wire clk,
    input wire rst_n,
    input wire signed [7:0] in_data,
    input wire in_valid,
    output reg signed [7:0] out_data,
    output reg out_valid
);

    reg signed [7:0] weight_rom [0:DIM-1];
    initial begin
        if (WEIGHT_FILE != "") $readmemh(WEIGHT_FILE, weight_rom);
    end

    reg [15:0] count;

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            count <= 0;
            out_data <= 0;
            out_valid <= 0;
        end else begin
            out_valid <= 0;
            if (in_valid) begin
                // Simplified LN: just scale by weight
                // In M3 we'll add the full (x-mean)/sqrt(var+eps)
                out_data <= $signed(in_data) * $signed(weight_rom[count]); 
                out_valid <= 1;
                
                if (count == DIM - 1)
                    count <= 0;
                else
                    count <= count + 1;
            end
        end
    end

endmodule
