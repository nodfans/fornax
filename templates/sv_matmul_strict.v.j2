/*
 * sv_matmul_strict.v - strict attention context for seq_len > 1
 * scores: [SEQ_LEN x SEQ_LEN], V: [SEQ_LEN x HEAD_DIM], out: [SEQ_LEN x HEAD_DIM]
 */

module sv_matmul_strict #(
    parameter DIM = 128,
    parameter SEQ_LEN = 4,
    parameter NUM_HEADS = 1,
    parameter HEAD_DIM = 32
)(
    input wire clk,
    input wire rst_n,
    input wire signed [7:0] in_a_data, // scores stream row-major
    input wire signed [7:0] in_b_data, // V stream
    input wire in_a_valid,
    input wire in_b_valid,
    output reg signed [7:0] out_data,
    output reg out_valid
);
    localparam SCORE_TOTAL = NUM_HEADS * SEQ_LEN * SEQ_LEN;
    reg signed [7:0] score_buf [0:SCORE_TOTAL-1];
    reg signed [7:0] v_buf [0:DIM-1];
    reg [15:0] s_count;
    reg [15:0] v_count;
    reg has_s;
    reg has_v;
    reg processing;
    reg [15:0] h_idx;
    reg [15:0] q_idx;
    reg [15:0] d_idx;
    reg [15:0] k_idx;
    reg signed [31:0] acc;
    integer i;

    function [15:0] score_idx;
        input [15:0] h;
        input [15:0] q;
        input [15:0] k;
        begin
            score_idx = h * (SEQ_LEN * SEQ_LEN) + q * SEQ_LEN + k;
        end
    endfunction

    function [15:0] v_idx;
        input [15:0] h;
        input [15:0] k;
        input [15:0] d;
        begin
            v_idx = h * (SEQ_LEN * HEAD_DIM) + k * HEAD_DIM + d;
        end
    endfunction

    wire signed [31:0] mul_term;
    wire signed [31:0] curr_acc;
    wire signed [31:0] curr_shifted;
    assign mul_term = $signed(score_buf[score_idx(h_idx, q_idx, k_idx)]) * $signed(v_buf[v_idx(h_idx, k_idx, d_idx)]);
    assign curr_acc = acc + mul_term;
    assign curr_shifted = curr_acc >>> 7;

    initial begin
        for (i = 0; i < SCORE_TOTAL; i = i + 1) score_buf[i] = 0;
        for (i = 0; i < DIM; i = i + 1) v_buf[i] = 0;
    end

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            s_count <= 0;
            v_count <= 0;
            has_s <= 0;
            has_v <= 0;
            processing <= 0;
            h_idx <= 0;
            q_idx <= 0;
            d_idx <= 0;
            k_idx <= 0;
            acc <= 0;
            out_data <= 0;
            out_valid <= 0;
        end else begin
            out_valid <= 0;

            if (in_a_valid) begin
                score_buf[s_count] <= in_a_data;
                if (s_count == SCORE_TOTAL - 1) begin
                    s_count <= 0;
                    has_s <= 1;
                end else begin
                    s_count <= s_count + 1;
                end
            end

            if (in_b_valid) begin
                v_buf[v_count] <= in_b_data;
                if (v_count == DIM - 1) begin
                    v_count <= 0;
                    has_v <= 1;
                end else begin
                    v_count <= v_count + 1;
                end
            end

            if (!processing && has_s && has_v) begin
                processing <= 1;
                has_s <= 0;
                has_v <= 0;
                h_idx <= 0;
                q_idx <= 0;
                d_idx <= 0;
                k_idx <= 0;
                acc <= 0;
            end

            if (processing) begin
                acc <= curr_acc;
                if (k_idx == SEQ_LEN - 1) begin
                    out_data <= (curr_acc > 16256) ? 8'sh7f :
                                (curr_acc < -16384) ? 8'sh80 :
                                curr_shifted[7:0];
                    out_valid <= 1;
                    acc <= 0;
                    k_idx <= 0;
                    if (d_idx == HEAD_DIM - 1) begin
                        d_idx <= 0;
                        if (q_idx == SEQ_LEN - 1) begin
                            q_idx <= 0;
                            if (h_idx == NUM_HEADS - 1) begin
                                h_idx <= 0;
                                processing <= 0;
                            end else begin
                                h_idx <= h_idx + 1;
                            end
                        end else begin
                            q_idx <= q_idx + 1;
                        end
                    end else begin
                        d_idx <= d_idx + 1;
                    end
                end else begin
                    k_idx <= k_idx + 1;
                end
            end
        end
    end
endmodule
