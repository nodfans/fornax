/*
 * matmul.v - Fornax M1 
 * Multiplies Input Vector (1 x InFeatures) with Weight Matrix (InFeatures x OutFeatures)
 * 
 * Precision: INT8
 * Accumulation: INT32
 */

module matmul #(
    parameter IN_FEATURES = 896,
    parameter OUT_FEATURES = 896,
    parameter WEIGHT_FILE = ""
)(
    input wire clk,
    input wire rst_n,
    input wire signed [7:0] in_data,
    input wire in_valid,
    output reg signed [31:0] out_data,
    output reg out_valid
);

    // Weight Storage - Explicitly SIGNED
    reg signed [7:0] weight_rom [0:IN_FEATURES*OUT_FEATURES-1];
    initial begin
        $readmemh(WEIGHT_FILE, weight_rom);
    end

    // Control Logic
    reg [15:0] in_count;   
    reg [15:0] out_count;  
    reg signed [31:0] acc;

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            in_count <= 0;
            out_count <= 0;
            acc <= 0;
            out_data <= 0;
            out_valid <= 0;
        end else begin
            out_valid <= 0;
            if (in_valid) begin
                // Simple Serial MAC logic
                if (in_count == IN_FEATURES - 1) begin
                    in_count <= 0;
                    // Final sum for this output element
                    out_data <= acc + ($signed(in_data) * $signed(weight_rom[out_count * IN_FEATURES + in_count]));
                    out_valid <= 1;
                    acc <= 0;
                    if (out_count == OUT_FEATURES - 1)
                        out_count <= 0;
                    else
                        out_count <= out_count + 1;
                end else begin
                    acc <= acc + ($signed(in_data) * $signed(weight_rom[out_count * IN_FEATURES + in_count]));
                    in_count <= in_count + 1;
                end
            end
        end
    end

endmodule
