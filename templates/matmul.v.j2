/*
 * matmul.v - Fornax M1 
 * Multiplies Input Vector (1 x InFeatures) with Weight Matrix (InFeatures x OutFeatures)
 * 
 * Precision: INT8
 * Accumulation: INT32
 */

module matmul #(
    parameter IN_FEATURES = 896,
    parameter OUT_FEATURES = 896,
    parameter WEIGHT_FILE = ""
)(
    input wire clk,
    input wire rst_n,
    input wire signed [7:0] in_data,
    input wire in_valid,
    output reg signed [31:0] out_data,
    output reg out_valid
);

    // Weight Storage - Explicitly SIGNED
    reg signed [7:0] weight_rom [0:IN_FEATURES*OUT_FEATURES-1];
    // Internal Buffer for the input vector
    reg signed [7:0] input_buffer [0:IN_FEATURES-1];
    
    integer i;
    initial begin
        for (i = 0; i < IN_FEATURES*OUT_FEATURES; i = i + 1) weight_rom[i] = 0;
        if (WEIGHT_FILE != "") $readmemh(WEIGHT_FILE, weight_rom);
        for (i = 0; i < IN_FEATURES; i = i + 1) begin
            input_buffer[i] = 0;
        end
    end

    // Control Logic
    reg signed [31:0] acc;
    reg [15:0] in_count;       // Used for buffering input
    reg [15:0] out_feat_count; // Iterates through output features
    reg [15:0] mac_count;      // Iterates through MACs for a single output feature
    reg [1:0] state;           // 0: Idle/Capture, 1: Processing

    wire [31:0] weight_idx = out_feat_count * IN_FEATURES + mac_count;

    // State Machine
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            acc <= 0;
            in_count <= 0;
            out_feat_count <= 0;
            mac_count <= 0;
            state <= 0;
            out_data <= 0;
            out_valid <= 0;
        end else begin
            out_valid <= 0; // Default to not valid
            case (state)
                0: begin // Capture Input Vector
                    if (in_valid) begin
                        input_buffer[in_count] <= in_data;
                        if (in_count == IN_FEATURES - 1) begin
                            state <= 1;
                            in_count <= 0; // Reset for next capture
                            // Also reset processing counters for the new vector
                            out_feat_count <= 0;
                            mac_count <= 0;
                            acc <= 0; // Reset accumulator for first MAC
                        end else begin
                            in_count <= in_count + 1;
                        end
                    end
                end
                
                1: begin // Sequential MAC for each OUT_FEATURE
                    // Perform MAC operation
                    acc <= acc + $signed(input_buffer[mac_count]) * $signed(weight_rom[weight_idx]);
                    
                    if (mac_count == IN_FEATURES - 1) begin
                        // This is the last MAC for the current output feature
                        // The 'acc' register holds the sum of the previous IN_FEATURES-1 products.
                        // The final product is added here to form the complete sum.
                        out_data <= acc + $signed(input_buffer[mac_count]) * $signed(weight_rom[weight_idx]);
                        out_valid <= 1;
                        acc <= 0; // Reset accumulator for the next output feature
                        mac_count <= 0; // Reset MAC counter for the next output feature
                        
                        if (out_feat_count == OUT_FEATURES - 1) begin
                            // All output features calculated for the current input vector
                            out_feat_count <= 0; // Reset for next input vector
                            state <= 0; // Ready for next input vector capture
                        end else begin
                            out_feat_count <= out_feat_count + 1; // Move to the next output feature
                        end
                    end else begin
                        mac_count <= mac_count + 1; // Continue MACs for the current output feature
                    end
                end
                default: begin // Should not happen
                    state <= 0;
                    acc <= 0;
                    in_count <= 0;
                    out_feat_count <= 0;
                    mac_count <= 0;
                end
            endcase
        end
    end

endmodule
