/*
 * scale_scalar.v - Fornax strict attention
 * Scalar fixed-point scaling for attention logits.
 */

module scale_scalar #(
    parameter MULTIPLIER = 8192,
    parameter SHIFT = 16
)(
    input wire clk,
    input wire rst_n,
    input wire signed [31:0] in_data,
    input wire in_valid,
    output reg signed [31:0] out_data,
    output reg out_valid
);
    wire signed [63:0] scaled = $signed(in_data) * $signed(MULTIPLIER);
    wire signed [31:0] shifted = scaled >>> SHIFT;

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            out_data <= 0;
            out_valid <= 0;
        end else begin
            out_valid <= 0;
            if (in_valid) begin
                out_data <= shifted;
                out_valid <= 1;
            end
        end
    end
endmodule

