/*
 * softmax_scalar.v - Fornax strict attention
 * For seq_len=1, softmax(logit) = 1.0 (quantized to 127).
 */

module softmax_scalar (
    input wire clk,
    input wire rst_n,
    input wire signed [31:0] in_data,
    input wire in_valid,
    output reg signed [7:0] out_data,
    output reg out_valid
);
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            out_data <= 0;
            out_valid <= 0;
        end else begin
            out_valid <= 0;
            if (in_valid) begin
                out_data <= 8'sh7f;
                out_valid <= 1;
            end
        end
    end
endmodule

