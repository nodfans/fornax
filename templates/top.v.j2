/*
 * top.v - Fornax M2 Transformer Block (Layer 0)
 * Structural wrapper connecting all modules.
 */

module fornax_layer0 (
    input wire clk,
    input wire rst_n,
    input wire signed [7:0] in_data,
    input wire in_valid,
    output wire signed [31:0] out_data,
    output wire out_valid
);

    // Intermediate signals
    {% for op in ops %}
    wire signed [{{ 31 if op.type == "linear" else 7 }}:0] out_{{ op.name }};
    wire valid_{{ op.name }};
    {% endfor %}

    // Instantiations
    {% for op in ops %}
    {% set input_sig = "in_data" if op.input == "block_input" else "out_" + op.input %}
    {% set input_valid = "in_valid" if op.input == "block_input" else "valid_" + op.input %}
    
    // Width adaptation: Linear output is 32-bit, but next stages (LN/Linear) expect 8-bit.
    // In M2, we take bits [15:8] as a simple quantization/scaling 
    wire signed [7:0] {{ op.name }}_in_vec_8 = ({{ op.input == "block_input" or "layernorm" in op.input }}) ? {{ input_sig }}[7:0] : {{ input_sig }}[15:8];

    {% if op.type == "layernorm" %}
    layernorm #(
        .DIM({{ op.dim }}),
        .WEIGHT_FILE("{{ weight_metadata[op.weight_key].hex_path }}")
    ) inst_{{ op.name }} (
        .clk(clk),
        .rst_n(rst_n),
        .in_data({{ op.name }}_in_vec_8),
        .in_valid({{ input_valid }}),
        .out_data(out_{{ op.name }}),
        .out_valid(valid_{{ op.name }})
    );
    {% elif op.type == "linear" %}
    matmul #(
        .IN_FEATURES({{ op.in_features }}),
        .OUT_FEATURES({{ op.out_features }}),
        .WEIGHT_FILE("{{ weight_metadata[op.weight_key].hex_path }}")
    ) inst_{{ op.name }} (
        .clk(clk),
        .rst_n(rst_n),
        .in_data({{ op.name }}_in_vec_8),
        .in_valid({{ input_valid }}),
        .out_data(out_{{ op.name }}),
        .out_valid(valid_{{ op.name }})
    );
    {% endif %}
    {% endfor %}

    assign out_data = out_{{ ops[-1].name }};
    assign out_valid = valid_{{ ops[-1].name }};

endmodule
