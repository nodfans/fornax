/*
 * qk_dot.v - Fornax strict attention (seq_len=1 minimal path)
 * Dot product between Q and K vectors.
 */

module qk_dot #(
    parameter DIM = 128
)(
    input wire clk,
    input wire rst_n,
    input wire signed [7:0] in_a_data,
    input wire signed [7:0] in_b_data,
    input wire in_a_valid,
    input wire in_b_valid,
    output reg signed [31:0] out_data,
    output reg out_valid
);
    reg signed [7:0] a_buf [0:DIM-1];
    reg signed [7:0] b_buf [0:DIM-1];
    reg [15:0] a_count;
    reg [15:0] b_count;
    reg has_a;
    reg has_b;
    reg [15:0] mac_idx;
    reg signed [31:0] acc;
    reg processing;
    integer i;

    initial begin
        for (i = 0; i < DIM; i = i + 1) begin
            a_buf[i] = 0;
            b_buf[i] = 0;
        end
    end

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            a_count <= 0;
            b_count <= 0;
            has_a <= 0;
            has_b <= 0;
            mac_idx <= 0;
            acc <= 0;
            processing <= 0;
            out_data <= 0;
            out_valid <= 0;
        end else begin
            out_valid <= 0;

            if (in_a_valid) begin
                a_buf[a_count] <= in_a_data;
                if (a_count == DIM - 1) begin
                    a_count <= 0;
                    has_a <= 1;
                end else begin
                    a_count <= a_count + 1;
                end
            end

            if (in_b_valid) begin
                b_buf[b_count] <= in_b_data;
                if (b_count == DIM - 1) begin
                    b_count <= 0;
                    has_b <= 1;
                end else begin
                    b_count <= b_count + 1;
                end
            end

            if (!processing && has_a && has_b) begin
                processing <= 1;
                mac_idx <= 0;
                acc <= 0;
                has_a <= 0;
                has_b <= 0;
            end

            if (processing) begin
                acc <= acc + $signed(a_buf[mac_idx]) * $signed(b_buf[mac_idx]);
                if (mac_idx == DIM - 1) begin
                    out_data <= acc + $signed(a_buf[mac_idx]) * $signed(b_buf[mac_idx]);
                    out_valid <= 1;
                    processing <= 0;
                    mac_idx <= 0;
                end else begin
                    mac_idx <= mac_idx + 1;
                end
            end
        end
    end
endmodule

