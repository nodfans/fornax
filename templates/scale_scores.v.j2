/*
 * scale_scores.v - scales logits matrix stream element-wise.
 */

module scale_scores #(
    parameter SEQ_LEN = 4,
    parameter NUM_HEADS = 1,
    parameter MULTIPLIER = 8192,
    parameter SHIFT = 16
)(
    input wire clk,
    input wire rst_n,
    input wire signed [31:0] in_data,
    input wire in_valid,
    output reg signed [15:0] out_data,
    output reg out_valid
);
    localparam TOTAL = NUM_HEADS * SEQ_LEN * SEQ_LEN;
    reg [15:0] count;
    wire signed [63:0] scaled = $signed(in_data) * $signed(MULTIPLIER);
    wire signed [31:0] shifted = scaled >>> SHIFT;

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            count <= 0;
            out_data <= 0;
            out_valid <= 0;
        end else begin
            out_valid <= 0;
            if (in_valid) begin
                out_data <= (shifted > 32767) ? 16'sh7fff :
                            (shifted < -32768) ? 16'sh8000 :
                            shifted[15:0];
                out_valid <= 1;
                if (count == TOTAL - 1)
                    count <= 0;
                else
                    count <= count + 1;
            end
        end
    end
endmodule
