/*
 * matmul_qk.v - Fornax M3
 * Pairwise Q/K interaction (streaming): score_i = q_i * k_i
 */

module matmul_qk #(
    parameter DIM = 128,
    parameter SHIFT = 7
)(
    input wire clk,
    input wire rst_n,
    input wire signed [7:0] in_a_data,
    input wire signed [7:0] in_b_data,
    input wire in_a_valid,
    input wire in_b_valid,
    output reg signed [7:0] out_data,
    output reg out_valid
);
    reg [15:0] count;
    wire signed [15:0] prod = $signed(in_a_data) * $signed(in_b_data);
    wire signed [15:0] shifted = prod >>> SHIFT;

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            count <= 0;
            out_data <= 0;
            out_valid <= 0;
        end else begin
            out_valid <= 0;
            if (in_a_valid && in_b_valid) begin
                out_data <= (shifted > 127) ? 8'sh7f :
                            (shifted < -128) ? 8'sh80 :
                            shifted[7:0];
                out_valid <= 1;
                if (count == DIM - 1)
                    count <= 0;
                else
                    count <= count + 1;
            end
        end
    end
endmodule
