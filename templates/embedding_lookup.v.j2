/*
 * embedding_lookup.v - Token embedding row streamer
 * Reads one token row from embedding table and emits DIM int8 values.
 */

module embedding_lookup #(
    parameter integer VOCAB_SIZE = 2048,
    parameter integer DIM = 128,
    parameter integer TOKEN_ID = 0,
    parameter WEIGHT_FILE = "weights.hex"
) (
    input wire clk,
    input wire rst_n,
    input wire signed [7:0] in_data,
    input wire in_valid,
    output reg signed [7:0] out_data,
    output reg out_valid
);
    localparam integer TABLE_SIZE = VOCAB_SIZE * DIM;
    integer i;
    integer base_idx;
    reg started;
    reg prev_in_valid;
    reg [31:0] idx;
    reg signed [7:0] emb_mem [0:TABLE_SIZE-1];

    initial begin
        $readmemh(WEIGHT_FILE, emb_mem);
        started = 0;
        prev_in_valid = 0;
        idx = 0;
        out_data = 0;
        out_valid = 0;
    end

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            started <= 0;
            prev_in_valid <= 0;
            idx <= 0;
            out_data <= 0;
            out_valid <= 0;
        end else begin
            prev_in_valid <= in_valid;
            out_valid <= 0;

            // Trigger once on rising edge of in_valid.
            if (!started && in_valid && !prev_in_valid) begin
                started <= 1;
                idx <= 0;
            end

            if (started) begin
                base_idx = TOKEN_ID * DIM;
                out_data <= emb_mem[base_idx + idx];
                out_valid <= 1;
                if (idx == (DIM - 1)) begin
                    started <= 0;
                    idx <= 0;
                end else begin
                    idx <= idx + 1;
                end
            end
        end
    end
endmodule
