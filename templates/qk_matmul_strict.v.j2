/*
 * qk_matmul_strict.v - strict attention for seq_len > 1
 * Q, K are flattened as [seq_len][head_dim].
 * Output logits stream is row-major [q_idx][k_idx] in int32.
 */

module qk_matmul_strict #(
    parameter DIM = 128,
    parameter SEQ_LEN = 4,
    parameter NUM_HEADS = 1,
    parameter HEAD_DIM = 32
)(
    input wire clk,
    input wire rst_n,
    input wire signed [7:0] in_a_data,
    input wire signed [7:0] in_b_data,
    input wire in_a_valid,
    input wire in_b_valid,
    output reg signed [31:0] out_data,
    output reg out_valid
);
    reg signed [7:0] q_buf [0:DIM-1];
    reg signed [7:0] k_buf [0:DIM-1];
    reg [15:0] q_count;
    reg [15:0] k_count;
    reg has_q;
    reg has_k;
    reg processing;
    reg [15:0] h_idx;
    reg [15:0] q_idx;
    reg [15:0] k_idx;
    reg [15:0] d_idx;
    reg signed [31:0] acc;
    integer i;

    function [15:0] flat_idx;
        input [15:0] h;
        input [15:0] s;
        input [15:0] d;
        begin
            flat_idx = h * (SEQ_LEN * HEAD_DIM) + s * HEAD_DIM + d;
        end
    endfunction

    initial begin
        for (i = 0; i < DIM; i = i + 1) begin
            q_buf[i] = 0;
            k_buf[i] = 0;
        end
    end

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            q_count <= 0;
            k_count <= 0;
            has_q <= 0;
            has_k <= 0;
            processing <= 0;
            h_idx <= 0;
            q_idx <= 0;
            k_idx <= 0;
            d_idx <= 0;
            acc <= 0;
            out_data <= 0;
            out_valid <= 0;
        end else begin
            out_valid <= 0;

            if (in_a_valid) begin
                q_buf[q_count] <= in_a_data;
                if (q_count == DIM - 1) begin
                    q_count <= 0;
                    has_q <= 1;
                end else begin
                    q_count <= q_count + 1;
                end
            end

            if (in_b_valid) begin
                k_buf[k_count] <= in_b_data;
                if (k_count == DIM - 1) begin
                    k_count <= 0;
                    has_k <= 1;
                end else begin
                    k_count <= k_count + 1;
                end
            end

            if (!processing && has_q && has_k) begin
                processing <= 1;
                has_q <= 0;
                has_k <= 0;
                h_idx <= 0;
                q_idx <= 0;
                k_idx <= 0;
                d_idx <= 0;
                acc <= 0;
            end

            if (processing) begin
                acc <= acc + $signed(q_buf[flat_idx(h_idx, q_idx, d_idx)]) * $signed(k_buf[flat_idx(h_idx, k_idx, d_idx)]);
                if (d_idx == HEAD_DIM - 1) begin
                    out_data <= acc + $signed(q_buf[flat_idx(h_idx, q_idx, d_idx)]) * $signed(k_buf[flat_idx(h_idx, k_idx, d_idx)]);
                    out_valid <= 1;
                    acc <= 0;
                    d_idx <= 0;
                    if (k_idx == SEQ_LEN - 1) begin
                        k_idx <= 0;
                        if (q_idx == SEQ_LEN - 1) begin
                            q_idx <= 0;
                            if (h_idx == NUM_HEADS - 1) begin
                                h_idx <= 0;
                                processing <= 0;
                            end else begin
                                h_idx <= h_idx + 1;
                            end
                        end else begin
                            q_idx <= q_idx + 1;
                        end
                    end else begin
                        k_idx <= k_idx + 1;
                    end
                end else begin
                    d_idx <= d_idx + 1;
                end
            end
        end
    end
endmodule
