/*
 * matmul_sv.v - Fornax M3
 * Pairwise score/value interaction (streaming): context_i = score_i * v_i
 */

module matmul_sv #(
    parameter DIM = 128,
    parameter SHIFT = 7
)(
    input wire clk,
    input wire rst_n,
    input wire signed [7:0] in_a_data,
    input wire signed [7:0] in_b_data,
    input wire in_a_valid,
    input wire in_b_valid,
    output reg signed [7:0] out_data,
    output reg out_valid
);
    reg signed [7:0] a_buf [0:DIM-1];
    reg signed [7:0] b_buf [0:DIM-1];
    reg [15:0] a_count;
    reg [15:0] b_count;
    reg [15:0] out_count;
    reg has_a;
    reg has_b;
    reg outputting;
    integer i;

    wire signed [15:0] prod = $signed(a_buf[out_count]) * $signed(b_buf[out_count]);
    wire signed [15:0] shifted = prod >>> SHIFT;

    initial begin
        for (i = 0; i < DIM; i = i + 1) begin
            a_buf[i] = 0;
            b_buf[i] = 0;
        end
    end

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            a_count <= 0;
            b_count <= 0;
            out_count <= 0;
            has_a <= 0;
            has_b <= 0;
            outputting <= 0;
            out_data <= 0;
            out_valid <= 0;
        end else begin
            out_valid <= 0;

            if (in_a_valid) begin
                a_buf[a_count] <= in_a_data;
                if (a_count == DIM - 1) begin
                    a_count <= 0;
                    has_a <= 1;
                end else begin
                    a_count <= a_count + 1;
                end
            end

            if (in_b_valid) begin
                b_buf[b_count] <= in_b_data;
                if (b_count == DIM - 1) begin
                    b_count <= 0;
                    has_b <= 1;
                end else begin
                    b_count <= b_count + 1;
                end
            end

            if (!outputting && has_a && has_b) begin
                outputting <= 1;
                out_count <= 0;
                has_a <= 0;
                has_b <= 0;
            end

            if (outputting) begin
                out_data <= (shifted > 127) ? 8'sh7f :
                            (shifted < -128) ? 8'sh80 :
                            shifted[7:0];
                out_valid <= 1;
                if (out_count == DIM - 1) begin
                    out_count <= 0;
                    outputting <= 0;
                end else begin
                    out_count <= out_count + 1;
                end
            end
        end
    end
endmodule
