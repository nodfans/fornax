/*
 * sv_matmul.v - Fornax strict attention (seq_len=1 minimal path)
 * context_i = softmax_scalar * v_i
 */

module sv_matmul #(
    parameter DIM = 128,
    parameter SHIFT = 7
)(
    input wire clk,
    input wire rst_n,
    input wire signed [7:0] in_a_data, // scalar score
    input wire signed [7:0] in_b_data, // V stream
    input wire in_a_valid,
    input wire in_b_valid,
    output reg signed [7:0] out_data,
    output reg out_valid
);
    reg signed [7:0] score;
    reg score_valid;
    reg signed [7:0] v_buf [0:DIM-1];
    reg [15:0] v_count;
    reg has_v;
    reg [15:0] out_count;
    reg outputting;
    integer i;

    wire signed [15:0] prod = $signed(score) * $signed(v_buf[out_count]);
    wire signed [15:0] shifted = prod >>> SHIFT;

    initial begin
        for (i = 0; i < DIM; i = i + 1) begin
            v_buf[i] = 0;
        end
    end

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            score <= 0;
            score_valid <= 0;
            v_count <= 0;
            has_v <= 0;
            out_count <= 0;
            outputting <= 0;
            out_data <= 0;
            out_valid <= 0;
        end else begin
            out_valid <= 0;

            if (in_a_valid) begin
                score <= in_a_data;
                score_valid <= 1;
            end

            if (in_b_valid) begin
                v_buf[v_count] <= in_b_data;
                if (v_count == DIM - 1) begin
                    v_count <= 0;
                    has_v <= 1;
                end else begin
                    v_count <= v_count + 1;
                end
            end

            if (!outputting && score_valid && has_v) begin
                outputting <= 1;
                out_count <= 0;
                has_v <= 0;
            end

            if (outputting) begin
                out_data <= (shifted > 127) ? 8'sh7f :
                            (shifted < -128) ? 8'sh80 :
                            shifted[7:0];
                out_valid <= 1;
                if (out_count == DIM - 1) begin
                    out_count <= 0;
                    outputting <= 0;
                end else begin
                    out_count <= out_count + 1;
                end
            end
        end
    end
endmodule

