/*
 * softmax_rows.v - row-wise softmax for score matrix stream [SEQ_LEN x SEQ_LEN].
 */

module softmax_rows #(
    parameter SEQ_LEN = 4,
    parameter NUM_HEADS = 1,
    parameter DIFF_MULT = 14
)(
    input wire clk,
    input wire rst_n,
    input wire signed [15:0] in_data,
    input wire in_valid,
    output reg signed [7:0] out_data,
    output reg out_valid
);
    localparam TOTAL = NUM_HEADS * SEQ_LEN * SEQ_LEN;
    localparam TOTAL_ROWS = NUM_HEADS * SEQ_LEN;
    reg signed [15:0] score_buf [0:TOTAL-1];
    reg [15:0] in_count;
    reg has_input;
    reg [15:0] row_idx;
    reg [15:0] col_idx;
    reg [1:0] state;
    reg signed [15:0] row_max;
    reg [23:0] row_sum;
    wire [15:0] curr_diff;
    wire [31:0] diff_scaled;
    wire [15:0] lut_diff;
    wire [7:0] curr_exp;
    wire [15:0] norm_val;
    integer i;

    function [7:0] exp_lut;
        input [15:0] d;
        begin
            case (d)
                0: exp_lut = 8'hff;
                1: exp_lut = 8'hef;
                2: exp_lut = 8'he1;
                3: exp_lut = 8'hd3;
                4: exp_lut = 8'hc6;
                5: exp_lut = 8'hba;
                6: exp_lut = 8'haf;
                7: exp_lut = 8'ha4;
                8: exp_lut = 8'h9a;
                9: exp_lut = 8'h91;
                10: exp_lut = 8'h88;
                11: exp_lut = 8'h80;
                12: exp_lut = 8'h78;
                13: exp_lut = 8'h71;
                14: exp_lut = 8'h6a;
                15: exp_lut = 8'h63;
                16: exp_lut = 8'h5d;
                17: exp_lut = 8'h58;
                18: exp_lut = 8'h52;
                19: exp_lut = 8'h4d;
                20: exp_lut = 8'h49;
                21: exp_lut = 8'h44;
                22: exp_lut = 8'h40;
                23: exp_lut = 8'h3c;
                24: exp_lut = 8'h38;
                25: exp_lut = 8'h35;
                26: exp_lut = 8'h32;
                27: exp_lut = 8'h2f;
                28: exp_lut = 8'h2c;
                29: exp_lut = 8'h29;
                30: exp_lut = 8'h27;
                31: exp_lut = 8'h24;
                32: exp_lut = 8'h22;
                33: exp_lut = 8'h20;
                34: exp_lut = 8'h1e;
                35: exp_lut = 8'h1c;
                36: exp_lut = 8'h1a;
                37: exp_lut = 8'h19;
                38: exp_lut = 8'h17;
                39: exp_lut = 8'h16;
                40: exp_lut = 8'h14;
                41: exp_lut = 8'h13;
                42: exp_lut = 8'h12;
                43: exp_lut = 8'h11;
                44: exp_lut = 8'h10;
                45: exp_lut = 8'h0f;
                46: exp_lut = 8'h0e;
                47: exp_lut = 8'h0d;
                48: exp_lut = 8'h0c;
                49: exp_lut = 8'h0b;
                50: exp_lut = 8'h0b;
                51: exp_lut = 8'h0a;
                52: exp_lut = 8'h09;
                53: exp_lut = 8'h09;
                54: exp_lut = 8'h08;
                55: exp_lut = 8'h08;
                56: exp_lut = 8'h07;
                57: exp_lut = 8'h07;
                58: exp_lut = 8'h06;
                59: exp_lut = 8'h06;
                60: exp_lut = 8'h05;
                61: exp_lut = 8'h05;
                62: exp_lut = 8'h05;
                63: exp_lut = 8'h04;
                64: exp_lut = 8'h04;
                65: exp_lut = 8'h04;
                66: exp_lut = 8'h04;
                67: exp_lut = 8'h03;
                68: exp_lut = 8'h03;
                69: exp_lut = 8'h03;
                70: exp_lut = 8'h03;
                71: exp_lut = 8'h03;
                72: exp_lut = 8'h02;
                73: exp_lut = 8'h02;
                74: exp_lut = 8'h02;
                75: exp_lut = 8'h02;
                76: exp_lut = 8'h02;
                77: exp_lut = 8'h02;
                78: exp_lut = 8'h01;
                79: exp_lut = 8'h01;
                80: exp_lut = 8'h01;
                81: exp_lut = 8'h01;
                82: exp_lut = 8'h01;
                83: exp_lut = 8'h01;
                84: exp_lut = 8'h01;
                85: exp_lut = 8'h01;
                86: exp_lut = 8'h01;
                87: exp_lut = 8'h01;
                88: exp_lut = 8'h01;
                89: exp_lut = 8'h00;
                90: exp_lut = 8'h00;
                91: exp_lut = 8'h00;
                92: exp_lut = 8'h00;
                93: exp_lut = 8'h00;
                94: exp_lut = 8'h00;
                95: exp_lut = 8'h00;
                96: exp_lut = 8'h00;
                97: exp_lut = 8'h00;
                98: exp_lut = 8'h00;
                99: exp_lut = 8'h00;
                100: exp_lut = 8'h00;
                101: exp_lut = 8'h00;
                102: exp_lut = 8'h00;
                103: exp_lut = 8'h00;
                104: exp_lut = 8'h00;
                105: exp_lut = 8'h00;
                106: exp_lut = 8'h00;
                107: exp_lut = 8'h00;
                108: exp_lut = 8'h00;
                109: exp_lut = 8'h00;
                110: exp_lut = 8'h00;
                111: exp_lut = 8'h00;
                112: exp_lut = 8'h00;
                113: exp_lut = 8'h00;
                114: exp_lut = 8'h00;
                115: exp_lut = 8'h00;
                116: exp_lut = 8'h00;
                117: exp_lut = 8'h00;
                118: exp_lut = 8'h00;
                119: exp_lut = 8'h00;
                120: exp_lut = 8'h00;
                121: exp_lut = 8'h00;
                122: exp_lut = 8'h00;
                123: exp_lut = 8'h00;
                124: exp_lut = 8'h00;
                125: exp_lut = 8'h00;
                126: exp_lut = 8'h00;
                127: exp_lut = 8'h00;
                default: exp_lut = 8'h00;
            endcase
        end
    endfunction

    assign curr_diff = row_max - score_buf[row_idx * SEQ_LEN + col_idx];
    assign diff_scaled = curr_diff * DIFF_MULT;
    assign lut_diff = (diff_scaled > 127) ? 16'd127 : diff_scaled[15:0];
    assign curr_exp = exp_lut(lut_diff);
    assign norm_val = (row_sum == 0) ? 16'd0 : ((curr_exp * 8'd127) / row_sum);

    initial begin
        for (i = 0; i < TOTAL; i = i + 1) begin
            score_buf[i] = 0;
        end
    end

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            in_count <= 0;
            has_input <= 0;
            row_idx <= 0;
            col_idx <= 0;
            state <= 0;
            row_max <= -32768;
            row_sum <= 0;
            out_data <= 0;
            out_valid <= 0;
        end else begin
            out_valid <= 0;
            if (in_valid && !has_input && state == 0) begin
                score_buf[in_count] <= in_data;
                if (in_count == TOTAL - 1) begin
                    in_count <= 0;
                    has_input <= 1;
                    state <= 1;
                    row_idx <= 0;
                    col_idx <= 0;
                    row_max <= score_buf[0];
                    row_sum <= 0;
                end else begin
                    in_count <= in_count + 1;
                end
            end

            case (state)
                1: begin // find row max
                    if (score_buf[row_idx * SEQ_LEN + col_idx] > row_max)
                        row_max <= score_buf[row_idx * SEQ_LEN + col_idx];
                    if (col_idx == SEQ_LEN - 1) begin
                        col_idx <= 0;
                        row_sum <= 0;
                        state <= 2;
                    end else begin
                        col_idx <= col_idx + 1;
                    end
                end
                2: begin // row exp sum
                    row_sum <= row_sum + curr_exp;
                    if (col_idx == SEQ_LEN - 1) begin
                        col_idx <= 0;
                        state <= 3;
                    end else begin
                        col_idx <= col_idx + 1;
                    end
                end
                3: begin // row normalize output
                    out_data <= (norm_val > 127) ? 8'sh7f : norm_val[7:0];
                    out_valid <= 1;
                    if (col_idx == SEQ_LEN - 1) begin
                        col_idx <= 0;
                        if (row_idx == TOTAL_ROWS - 1) begin
                            row_idx <= 0;
                            row_max <= -32768;
                            state <= 0;
                            has_input <= 0;
                        end else begin
                            row_idx <= row_idx + 1;
                            row_max <= -32768;
                            state <= 1;
                        end
                    end else begin
                        col_idx <= col_idx + 1;
                    end
                end
            endcase
        end
    end
endmodule
